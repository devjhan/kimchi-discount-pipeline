{
  "additionalDirectories": ["governance/", "operations/", "telemetry/", "configs/", "applications/"],
  "permissions": {
    "allow": [
      "Bash(python -m domains.risk_engine.*)",
      "Bash(python -m domains.alpha_factory.*)",
      "Bash(python -m domains.audit_integrity.*)",
      "Bash(bash applications/daily_pipeline.sh:*)",
      "Read(governance/**)",
      "Read(.claude/hooks/**)",
      "mcp__bb9a3bd8-7422-48cc-8787-8ff8cc5441bf__slack_send_message",
      "mcp__d49a4519-3341-4883-9786-dc2e0e2aae3e__create_draft",
    ],
    "deny": [
      "Bash(crontab*)",
      "Bash(launchctl*)",
      "Bash(*kis_order*)",
      "Bash(*place_order*)",
      "Bash(*TTTC0802U*)",
      "Bash(*TTTC0801U*)",
      "Bash(*TTTC0803U*)",
      "Bash(*TTTC0851U*)",
      "Bash(*CTSC0008U*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/bootstrap/inject_session_state/entrypoint.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/context/inject_investment_contract/entrypoint.sh" },
          { "type": "command", "command": ".claude/hooks/context/inject_directive_context/entrypoint.sh" },
          { "type": "command", "command": ".claude/hooks/context/inject_guidelines/entrypoint.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Bash|Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/guard/pre_env_guard/entrypoint.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/guard/block_anti_patterns/entrypoint.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/quality/brief_citation_gate/entrypoint.sh" },
          { "type": "command", "command": ".claude/hooks/quality/lint_directives/entrypoint.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/quality/brief_citation_gate/entrypoint.sh --stop" }
        ]
      }
    ]
  }
}
