# OS
.DS_Store
**/.DS_Store

# Secrets — agent API keys (DART / KIS / FRED)
# actual secret dotenv (`.env` / `.env.local` / 레거시 `.env.agents`) 통째 ignore.
# template (`.env.example` / `.env.template`) 만 `!` exception 으로 추적.
# (`.env.*` 가 레거시 `.env.agents` 도 커버 — rename 전까지 남은 파일 보호.)
.env
.env.*
!.env.example
!.env.template
**/.env

# 사용자별 runtime config (yaml; .example 만 추적)
governance/runtime-policy.local.yaml
config/user/portfolio.yaml
config/user/behavior.yaml
config/user/manual_additions.yaml
config/user/exclusions.yaml
config/user/*.local.yaml
config/signals/macro/breadth.yaml

# Daily pipeline artifacts —
# operations/{date}/.trails/ 디렉토리는 ignore 하고 daily-brief.md 만 exception 으로 추적.

operations/**/.trails/
operations/

# 2026-06-02 operations/ 재편 완료 — 비일별 데이터는 telemetry/ · .cache/ · secrets/ · config/.

# telemetry/logs — hook / cron / launchd 실행 로그 (관측용, 누적 방지; 디렉토리는 .gitkeep 으로 유지)
telemetry/logs/
# telemetry/policy_drafts — commit 전 ephemeral policy draft (gitignore)
telemetry/policy_drafts/
# telemetry/audit (shadow-portfolio/{state.json,trade-log} / scheduler-state/ / violations/{bc}/
#   / breadth/ / subsidiaries/)  ·  telemetry/positions (_account/{summary,derived} + {ticker}/)
# · telemetry/nav-history (F-14: NAV 시계열 = 재생성-불가 증거)
# · telemetry/external_signals (ingest-external-signal 산출 = agent 생성 비재생성 append-only
#   증거; redaction(G21/G22) 후 저장이라 tracked 안전 — ADR-0008 분류축상 config 아닌 telemetry)
# · telemetry/segments/vectors.sqlite (모델버전 의존 재생성-불가 증거, ADR-0008)
# 는 추적 — gitignore 하지 않음 (audit trail / 상태 스냅샷 / retention class PERMANENT·STATE·SNAPSHOT·BINARY)

# telemetry G20 충돌 재실행본(.{N}) untrack — 디스크엔 남되 git 추적 안 함.
# retention GC(`make telemetry-gc-apply`)가 최신본을 canonical 로 정규화하므로 충돌본은 transient.
# 날짜본(`-YYYY-MM-DD.ext`)은 dot-digit 패턴이 아니라 비매칭 (예: `summary-2026-06-05.json` 추적됨,
# `summary-2026-06-05.1.json` 무시됨). logs/·policy_drafts/ 는 위에서 디렉토리째 ignore.
telemetry/**/*.[0-9].json
telemetry/**/*.[0-9][0-9].json
telemetry/**/*.[0-9].jsonl
telemetry/**/*.[0-9][0-9].jsonl
telemetry/**/*.[0-9].md
telemetry/**/*.[0-9][0-9].md
telemetry/**/*.[0-9].csv
telemetry/**/*.[0-9][0-9].csv

# .cache/ — DART corp index / financials 재생성 가능 캐시 (통째 ignore).
# F-15: top-level cache/ → 숨김 .cache/ (XDG 관례; 파일 단위 dotfile 산포 제거).
.cache/

# secrets/ — KIS OAuth token 등 API 자격증명, 절대 커밋 금지
secrets/

# Notify dispatch 결과 — 실행마다 생성되는 ephemeral artifact
operations/**/_notify-results.json

# Kiro compatibility layer
.kiro
