# ============================================================
# .env.example — investment_v2 SECRET-only template
# ============================================================
# 본 파일은 placeholder 만 포함 (실제 secret 없음) — git 추적 대상.
# Agent toolchain 도 본 파일은 read 가능 (env-guard 가 .example suffix 허용).
# Actual secrets 는 사용자가 별도 `.env` 작성:
#
#   cp .env.example .env
#   # → .env 안에 실제 secret 값 입력 (.gitignore + env-guard 보호)
#
# 본 파일은 **secret only** — API key / token / 계좌번호 정도만 포함.
# 비-secret runtime config 는 다음 yaml 들로 분리되어 있다:
#
#   governance/runtime-policy.yaml             (hard policy default)
#   governance/runtime-policy.local.yaml       (사용자 USER_ACKNOWLEDGED override)
#   config/user/portfolio.yaml    (Stage 5 portfolio context)
#   config/user/behavior.yaml    (Yahoo fallback 등 behavior switch)
#   config/signals/macro/breadth.yaml   (S&P breadth manual input)
#
# 각 yaml 은 `.example` template 가 git 추적되며, 실제 파일은 .gitignore.
# 자세한 매핑은 governance/procedures/config-files-reference.md 참고.
#
# secret 값은 산출물 / stdout / 로그에 절대 노출 금지 (G21).
# helper 는 infrastructure._common.utils.load_env_file() 로 Python 내부에서만 read.
# ============================================================

# ------------------------------------------------------------
# DART OPEN API  (Stage 1 / 2a / 3 / 3a / 3b 의존)
#   발급: https://opendart.fss.or.kr
# ------------------------------------------------------------
DART_API_KEY=

# ------------------------------------------------------------
# KIS OpenAPI  (Stage 1b / 1c / 3b + positions_sync 의존)
#   시세 read-only + G9b read-only 계좌 조회 (잔고 / 체결 / 매수가능 등 6종).
#   매매 / 주문 endpoint 는 코드 부재 + Bash deny + policy whitelist 3중 차단 (G9c).
#   계좌번호: `12345678-01` 형식 (CANO 8자리-ACNT_PRDT_CD 2자리).
#   read-only 계좌 조회 활성화: runtime-policy.local.yaml 에서
#     kis.read_only_account.enabled: true 설정 필요.
#   발급: https://apiportal.koreainvestment.com
# ------------------------------------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NUMBER=

# ------------------------------------------------------------
# FRED  (Stage 0 macro regime 의존)
#   발급: https://fred.stlouisfed.org/docs/api/api_key.html
# ------------------------------------------------------------
FRED_API_KEY=

# ------------------------------------------------------------
# Telegram  (기본 알림 채널 — TelegramAdapter, ADR-0017 로컬 직접 발송)
#   봇 생성: @BotFather 로 토큰 발급. chat id: @userinfobot / getUpdates.
#   두 값 모두 G21 secret (SECRET_ENV_KEYS 등록 — 로그/산출물 노출 금지).
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# SMTP  (기본 알림 채널 'email' — EmailAdapter, ADR-0017 로컬 직접 발송)
#   범용 SMTP 서버. Gmail 사용 시 SMTP_HOST=smtp.gmail.com + 앱 비밀번호.
#   SMTP_PORT: 587=STARTTLS(기본) / 465=SSL.
#   SMTP_PASSWORD 는 G21 secret (SECRET_ENV_KEYS 등록 — 로그/산출물 노출 금지).
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ------------------------------------------------------------
# Notification dispatcher
# ------------------------------------------------------------
# 기본(로컬 직접 발송, ADR-0017): email + telegram 채널은 로컬 파이프라인
# (run_daily_local.sh)에서 stdlib smtplib / urllib 로 직접 발송한다.
#
# slack / gmail 채널은 cloud routine (Anthropic Claude Code Routines)
# 의 Slack/Gmail MCP connector 위임형 — 로컬에서는 payload 만 생성하고
# 실제 발송은 하지 않는다(옵션 보존). 로컬 실발송은 email,telegram 사용.
#
#   NOTIFY_CHANNELS     : 활성 채널 CSV  (기본 email,telegram)
#   NOTIFY_EMAIL_TO     : 수신 메일 주소
#   NOTIFY_EMAIL_FROM   : 발신 메일 주소
#   NOTIFY_SLACK_CHANNEL: (옵션, slack 채널 MCP 위임) Slack 채널 ID
#
# KakaoTalk / Discord / Webhook 추가 시 각 adapter 가 required_env 항목
# 정의 (infrastructure/notify/ 참고).
# ------------------------------------------------------------
NOTIFY_CHANNELS=email,telegram
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
NOTIFY_SLACK_CHANNEL=

#-------------------------------------------------------------
# LLM dispatcher — Claude Code DeepSeek 백엔드 (ADR-0016)
# ------------------------------------------------------------
#   기본 vendor=claude-cli-deepseek: `claude` agentic harness 를 DeepSeek 의
#   Anthropic-호환 엔드포인트(api.deepseek.com/anthropic)로 redirect 한다.
#   본 키는 adapter 가 자식 프로세스 env 의 ANTHROPIC_AUTH_TOKEN 으로 주입하며,
#   ANTHROPIC_API_KEY 는 제거되어 Anthropic 은 호출/과금되지 않는다(Anthropic $0).
#   rollback: LLM_VENDOR=claude-cli (순수 Anthropic) 로 override.
#   키 값은 산출물/stdout/로그에 절대 노출 금지 (G21 — SECRET_ENV_KEYS 등록됨).
#   발급: https://platform.deepseek.com/api_keys
# ------------------------------------------------------------
DEEPSEEK_API_KEY=

# ------------------------------------------------------------
# Embedding  (segment-scoped profile 의 semantic 분류 — ADR-0012)
#   OpenAI-호환 /embeddings endpoint 호출 (infrastructure/embedding/client.py).
#   semantic 세그먼트 멤버십(concept anchor cosine)에만 필요 — 키 부재 시
#   semantic leaf 는 UNKNOWN(비매칭) 으로 graceful degrade (rule-based 선택은 계속).
#   벡터 가속 extra: pip install -e '.[semantic]'  (sqlite-vec; 미설치 시 stdlib
#   sqlite3 + brute-force cosine 로 정확 degrade).
#
#   EMBEDDING_API_KEY : 필수 (OpenAI: sk-...). 발급: https://platform.openai.com/api-keys
#   EMBEDDING_BASE_URL: 선택 — 기본 https://api.openai.com/v1 (OpenAI-호환 게이트웨이 시 override)
#   EMBEDDING_MODEL   : 선택 — 기본 text-embedding-3-small. 한국어 코호트 분리(지주/운영)에는
#                       text-embedding-3-large 권장 (절대 cosine·분리 마진 ↑, Task 6 §4 3-d).
#                       모델 변경 = 전량 재임베딩(vectors.sqlite 갱신).
#
#   회사 공개 공시 텍스트(MD&A "이사의 경영진단 및 분석의견")가 본 endpoint 로 전송됨
#   (ADR-0012 10-a 사용자 결정). 키 값은 산출물/stdout/로그에 절대 노출 금지 (G21).
# ------------------------------------------------------------
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
