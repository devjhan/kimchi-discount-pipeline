# ============================================================
# .env.example — investment_v2 SECRET-only template
# ============================================================
# 본 파일은 placeholder 만 포함 (실제 secret 없음) — git 추적 대상.
# Agent toolchain 도 본 파일은 read 가능 (env-guard 가 .example suffix 허용).
# Actual secrets 는 사용자가 별도 `.env` 작성:
#
#   cp .env.example .env
#   # → .env 안에 실제 secret 값 입력 (.gitignore + env-guard 보호)
#
# 본 파일은 **secret only** — API key / token / 계좌번호 정도만 포함.
# 비-secret runtime config 는 다음 yaml 들로 분리되어 있다:
#
#   governance/runtime-policy.yaml             (hard policy default)
#   governance/runtime-policy.local.yaml       (사용자 USER_ACKNOWLEDGED override)
#   operations/_user_context/portfolio.yaml    (Stage 5 portfolio context)
#   operations/_user_context/behavior.yaml    (Yahoo fallback 등 behavior switch)
#   operations/_external_signals/macro/breadth.yaml   (S&P breadth manual input)
#
# 각 yaml 은 `.example` template 가 git 추적되며, 실제 파일은 .gitignore.
# 자세한 매핑은 governance/procedures/config-files-reference.md 참고.
#
# secret 값은 산출물 / stdout / 로그에 절대 노출 금지 (G21).
# helper 는 infrastructure._common.utils.load_env_file() 로 Python 내부에서만 read.
# ============================================================

# ------------------------------------------------------------
# DART OPEN API  (Stage 1 / 2a / 3 / 3a / 3b 의존)
#   발급: https://opendart.fss.or.kr
# ------------------------------------------------------------
DART_API_KEY=

# ------------------------------------------------------------
# KIS OpenAPI  (Stage 1b / 1c / 3b + positions_sync 의존)
#   시세 read-only + G9b read-only 계좌 조회 (잔고 / 체결 / 매수가능 등 6종).
#   매매 / 주문 endpoint 는 코드 부재 + Bash deny + policy whitelist 3중 차단 (G9c).
#   계좌번호: `12345678-01` 형식 (CANO 8자리-ACNT_PRDT_CD 2자리).
#   read-only 계좌 조회 활성화: runtime-policy.local.yaml 에서
#     kis.read_only_account.enabled: true 설정 필요.
#   발급: https://apiportal.koreainvestment.com
# ------------------------------------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NUMBER=

# ------------------------------------------------------------
# FRED  (Stage 0 macro regime 의존)
#   발급: https://fred.stlouisfed.org/docs/api/api_key.html
# ------------------------------------------------------------
FRED_API_KEY=

# ------------------------------------------------------------
# Telegram  (옵셔널 — TelegramAdapter 는 deferred stub. 활성화 전까지 미사용)
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Notification dispatcher
# ------------------------------------------------------------
# 정식 등록 경로: Anthropic Claude Code Routines 의 Environment 탭
# (https://claude.ai/code/routines). cloud routine 안에서 secret-safe
# 하게 inject 된다.
#
# 본 .env 의 NOTIFY_* 항목은 **local 테스트 한정** — 실제 daily
# brief 발송은 cloud routine 안에서만 동작 (Slack/Gmail MCP connector 의
# OAuth scope 가 routine prompt 의 session 안에서만 유효).
#
#   NOTIFY_CHANNELS     : 활성 채널 CSV  예) slack,gmail
#   NOTIFY_SLACK_CHANNEL: Slack 발송 채널 ID  예) C0123456789
#   NOTIFY_EMAIL_TO     : Gmail 수신 주소
#   NOTIFY_EMAIL_FROM   : Gmail 발신 주소 (연결된 Gmail 계정)
#
# KakaoTalk / Discord / Webhook 추가 시 각 adapter 가 required_env 항목
# 정의 (infrastructure/notify/ 참고).
# ------------------------------------------------------------
NOTIFY_CHANNELS=slack,gmail
NOTIFY_SLACK_CHANNEL=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
